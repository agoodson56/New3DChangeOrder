# ─── Server-side Cloudflare Pages secret (set in Pages → Settings → Environment variables) ───
# Server-only. NOT prefixed with VITE_ so it never reaches the browser bundle.
GEMINI_API_KEY=

# ─── Cloudflare deployment secrets (set in GitHub → Settings → Secrets → Actions) ───
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ─── Optional security / limits (Cloudflare Pages env vars) ───
# Comma-separated allowed origins, or "*" to allow all. Defaults to same-origin.
ALLOWED_ORIGINS=https://new3dchangeorder.pages.dev
MAX_REQUEST_BYTES=30000000
RATE_LIMIT_PER_MINUTE=200
