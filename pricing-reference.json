  "change_order_workflow_tips": {
    "tip_1": "Always get site measurements before estimating add/move/change items",
    "tip_2": "Factor in cable runs and conduit requirements - often 50% of labor cost",
    "tip_3": "Program/configuration time is often 20-30% of installation time",
    "tip_4": "Testing and commissioning should be 10-15% of project total labor",
    "tip_5": "For moves, factor in decommissioning (10-20% of add cost) and recommissioning",
    "tip_6": "Materials cost can vary significantly by vendor and order quantity",
    "tip_7": "Weather and site access can impact labor productivity 20-50%",
    "tip_8": "Always include travel time in labor estimates (1-2 hours for first trip)"
  }
